        <!--  NODE 4 : Spatial Priority Attention  [NOVELTY]                -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <mxCell id="n4"
          value="&lt;b style='font-size:13px;'&gt;Layer Atensi 1 — Spatial Priority Attention&lt;/b&gt;
&lt;hr style='border:1px solid #d04a00; margin:4px 0;'/&gt;
&lt;span style='font-size:11px;'&gt;
  &lt;b&gt;Aturan Pakem Pelatih&lt;/b&gt;&lt;br/&gt;
  Menyuntikkan aturan biomekanika dasar&lt;br/&gt;
  pada sendi-sendi krusial gerakan latihan.&lt;br/&gt;
  &lt;i&gt;P_bio ∈ ℝ&lt;sup&gt;J&lt;/sup&gt; — prior eksplisit per kelas gerakan&lt;/i&gt;
&lt;/span&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;
                 fillColor=#ffe6cc;strokeColor=#d04a00;
                 fontColor=#1a1a2e;align=center;
                 arcSize=12;fontSize=12;verticalAlign=middle;shadow=1;"
          vertex="1" parent="1">
