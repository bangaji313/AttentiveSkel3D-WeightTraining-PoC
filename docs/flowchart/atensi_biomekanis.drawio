        </mxCell>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!--  NODE 6 : Temporal Attention  [NOVELTY]                        -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <mxCell id="n6"
          value="&lt;b style='font-size:13px;'&gt;Layer Atensi 3 — Temporal Attention&lt;/b&gt;
&lt;hr style='border:1px solid #9e4b00; margin:4px 0;'/&gt;
&lt;span style='font-size:11px;'&gt;
  &lt;b&gt;Fokus Waktu Kritis&lt;/b&gt;&lt;br/&gt;
  Seleksi frame / detik di mana&lt;br/&gt;
  kesalahan form paling sering terjadi.&lt;br/&gt;
  &lt;i&gt;&amp;beta; ∈ ℝ&lt;sup&gt;T&lt;/sup&gt; — bobot temporal per frame&lt;/i&gt;
&lt;/span&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;
                 fillColor=#fce4cc;strokeColor=#9e4b00;
                 fontColor=#1a1a2e;align=center;
                 arcSize=12;fontSize=12;verticalAlign=middle;shadow=1;"
          vertex="1" parent="1">
          <mxGeometry x="284" y="1002" width="600" height="120" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!--  NODE 7 : Element-wise Fusion & 3D-CNN                         -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <mxCell id="n7"
          value="&lt;b style='font-size:13px;'&gt;Element-wise Fusion &amp;amp; 3D-CNN Backbone&lt;/b&gt;
&lt;hr style='border:1px solid #666666; margin:4px 0;'/&gt;
&lt;span style='font-size:11px;'&gt;
  &lt;b&gt;Otak Pemroses Fitur Lanjutan&lt;/b&gt;&lt;br/&gt;
  F_final = (&amp;alpha; &amp;odot; &amp;beta;) &amp;odot; P_bio &amp;odot; F_raw&lt;br/&gt;
  Conv3D → BatchNorm → ReLU → MaxPool3D → FC Layer
&lt;/span&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;
                 fillColor=#f5f5f5;strokeColor=#666666;
                 fontColor=#1a1a2e;align=center;
                 arcSize=12;fontSize=12;verticalAlign=middle;shadow=1;"
          vertex="1" parent="1">
