        </mxCell>

        <!-- ══════════════════════════════════════════════════════════════ -->
        <!--  NODE 5 : Learned Spatial Attention  [NOVELTY]                 -->
        <!-- ══════════════════════════════════════════════════════════════ -->
        <mxCell id="n5"
          value="&lt;b style='font-size:13px;'&gt;Layer Atensi 2 — Learned Spatial Attention&lt;/b&gt;
&lt;hr style='border:1px solid #bf4040; margin:4px 0;'/&gt;
&lt;span style='font-size:11px;'&gt;
  &lt;b&gt;Adaptasi Mata Pelatih&lt;/b&gt;&lt;br/&gt;
  Penyesuaian dinamis terhadap&lt;br/&gt;
  sudut kamera &amp;amp; oklusi sendi.&lt;br/&gt;
  &lt;i&gt;&amp;alpha; = Softmax(W·F + b) — bobot dipelajari dari data&lt;/i&gt;
&lt;/span&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;
                 fillColor=#f8cecc;strokeColor=#bf4040;
                 fontColor=#1a1a2e;align=center;
                 arcSize=12;fontSize=12;verticalAlign=middle;shadow=1;"
          vertex="1" parent="1">
